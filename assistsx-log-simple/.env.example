VITE_SOCKET_URL=ws://localhost:3000

# 可选：本地 assistsx-js 仓库根目录绝对路径；开发模式下 Vite 会直连该目录下的 src/index.ts。勿提交本机路径，可复制为 .env.local（已由 *.local 忽略）。
# ASSISTSX_JS_LOCAL=

# 日志上报（可选，未设置时与示例仓库默认一致：仅 uploadKey 有内置默认值，baseUrl 由宿主诊断配置决定）
# 密钥：与宿主 uploadLogs / 诊断 uploadKey 一致；勿提交真实密钥到仓库，请用 .env.local
# VITE_LOG_UPLOAD_KEY=
# 方式一：整段日志服务 origin（优先）
# VITE_LOG_SERVICE_BASE_URL=https://log.example.com
# 方式二：主机 + 端口 + 协议（与方式一二选一；未设协议时默认 https）
# VITE_LOG_SERVICE_HOST=192.168.1.10
# VITE_LOG_SERVICE_PORT=8443
# VITE_LOG_SERVICE_PROTOCOL=http
